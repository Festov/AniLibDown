default_platform(:ios)

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  desc "Собрать подписанный .ipa для установки на iPhone"
  lane :build_ipa do
    UI.user_error!("Добавьте секрет APPLE_ID в GitHub") if ENV["APPLE_ID"].to_s.strip.empty?
    UI.user_error!("Добавьте секрет FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD") if ENV["FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD"].to_s.strip.empty?
    UI.user_error!("Добавьте секрет TEAM_ID в GitHub") if ENV["TEAM_ID"].to_s.strip.empty?

    if ENV["DEVICE_UDID"] && !ENV["DEVICE_UDID"].strip.empty?
      begin
        register_devices(
          devices: {
            "iPhone" => ENV["DEVICE_UDID"].strip
          }
        )
      rescue => e
        UI.important("Не удалось зарегистрировать устройство: #{e.message}")
        UI.important("Продолжаем без регистрации UDID...")
      end
    end

    begin
      produce(
        app_identifier: "top.aniliberty.AniLibDown",
        app_name: "AniLibDown",
        username: ENV["APPLE_ID"],
        team_id: ENV["TEAM_ID"],
        skip_itc: true,
        enable_services: {}
      )
    rescue => e
      UI.important("App ID уже существует или не удалось создать: #{e.message}")
    end

    cert(
      development: true,
      username: ENV["APPLE_ID"],
      team_id: ENV["TEAM_ID"]
    )

    sigh(
      development: true,
      app_identifier: "top.aniliberty.AniLibDown",
      username: ENV["APPLE_ID"],
      team_id: ENV["TEAM_ID"],
      force: true
    )

    profile_name = lane_context[SharedValues::SIGH_NAME]

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "AniLibDown/AniLibDown.xcodeproj",
      team_id: ENV["TEAM_ID"],
      targets: ["AniLibDown"],
      code_sign_identity: "Apple Development",
      profile_name: profile_name,
      build_configurations: ["Debug", "Release"]
    )

    build_app(
      project: "AniLibDown/AniLibDown.xcodeproj",
      scheme: "AniLibDown",
      configuration: "Release",
      export_method: "development",
      output_directory: "dist",
      output_name: "AniLibDown.ipa",
      clean: true
    )
  end
end
